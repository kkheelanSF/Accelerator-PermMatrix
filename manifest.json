{
  "manifest_version": 3,
  "name": "PermMatrix",
  "version": "1.0.2",
  "description": "One-click effective permission auditing for Salesforce.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "cookies"
  ],
  "host_permissions": [
    "*://*.salesforce.com/*",
    "*://*.force.com/*",
    "*://*.salesforce-setup.com/*"
  ]
}